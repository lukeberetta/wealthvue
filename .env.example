VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""

# Set to "true" to connect to the local Firebase Emulator Suite instead of production.
# Run the emulators first: firebase emulators:start
# The Emulator UI will be available at http://localhost:4000
VITE_USE_EMULATOR="false"

# Direct Cloud Function base URL (used when not behind Firebase Hosting rewrites)
# e.g. https://us-central1-wealthvue-e9f1b.cloudfunctions.net
VITE_API_BASE_URL=""

# Paddle (billing) — https://developer.paddle.com/
# Set VITE_PADDLE_ENVIRONMENT to "sandbox" for testing, "production" for live.
VITE_PADDLE_CLIENT_TOKEN=""
VITE_PADDLE_PRO_PRICE_ID=""
VITE_PADDLE_ENVIRONMENT="sandbox"
