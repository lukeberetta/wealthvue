rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Shared FX rate cache ─────────────────────────────────────────────
    // Any authenticated user can read; any authenticated user can write back
    // a fresh fetch. Prevents redundant external API calls across users.
    match /fxCache/{doc} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── User profile ─────────────────────────────────────────────────────
    // Only the owning user can read or write their document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // ── Assets subcollection ─────────────────────────────────────────
      match /assets/{assetId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // ── NAV history subcollection ────────────────────────────────────
      match /navHistory/{date} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}